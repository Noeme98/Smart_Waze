# Production / direct API URL (must end with /api, no trailing slash)
# VITE_API_URL=http://localhost:8000/api

# Local dev: use Vite proxy so the browser calls /api on port 5173 (avoids CORS & wrong-host HTML).
VITE_API_USE_PROXY=true
# Where Vite forwards /api (Django)
# VITE_PROXY_TARGET=http://127.0.0.1:8000

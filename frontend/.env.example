# --- Local dev ---
# Use Vite proxy so the browser calls /api on port 5173 (avoids CORS & wrong-host HTML).
VITE_API_USE_PROXY=true
# Where Vite forwards /api (Django)
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# --- Vercel / production frontend ---
# Vercel only hosts the React app. Deploy Django elsewhere (Railway, Render, Fly.io, VPS, etc.),
# then set this to your PUBLIC API root including /api (HTTPS required if your site is HTTPS):
# VITE_API_URL=https://your-django-host.example.com/api
# Build again after changing env vars in the Vercel dashboard (Vite bakes these in at build time).

# If VITE_API_URL is unset in production builds, the app falls back to localhost (will fail on Vercel).
# VITE_API_URL=http://localhost:8000/api
